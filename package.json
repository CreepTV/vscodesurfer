{
  "name": "vscodesurfer",
  "displayName": "VSCodeSurfer",
  "icon": "vscodesurfer-extension-logo.png",
  "description": "Play a local video file in a VS Code panel beside your code.",
  "version": "0.0.2",
  "publisher": "ConflictStudios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CreepTV/vscodesurfer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscodesurfer.start",
        "title": "Open Video Panel",
        "category": "VSCodeSurfer"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodesurfer",
          "title": "VSCodeSurfer",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "vscodesurfer": [
        {
          "id": "vscodesurfer.sidebar",
          "name": "Video Panel"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vscodesurfer.sidebar",
        "contents": "Open a video panel beside your code.\n\n[$(play) Open Video Panel](command:vscodesurfer.start)"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8"
  }
}
